generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}

model Attribute {
  id    Int     @id @default(autoincrement())
  categories Category
  name  String @unique
  dataTypes Type
}
enum Category{
  CERTIFICATION
  PROFESSIONAL_KNOWLEDGE
  PERSONAL_INFORMATION
  SOFT_SKILLS
}
enum Type{
  STRING
  MARKDOWN
  IMAGE
  NUMBER
  DATE
  PERIOD
  BOOLEAN
}