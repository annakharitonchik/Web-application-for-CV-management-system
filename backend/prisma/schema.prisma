generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
  moduleFormat  = "cjs"
}

datasource db {
  provider = "postgresql"
}


model Attribute {
  id    Int     @id @default(autoincrement())
  category Category
  name  String @unique
  dataType Type
  positions Position[]
}
enum Category{
  CERTIFICATION
  PROFESSIONAL_KNOWLEDGE
  PERSONAL_INFORMATION
  SOFT_SKILLS
}
enum Type{
  STRING
  MARKDOWN
  IMAGE
  NUMBER
  DATE
  PERIOD
  BOOLEAN
}

model Position {
  id    Int     @id @unique @default(autoincrement())
  name  String
  description String
  isPublic Boolean
  attributes Attribute[]
}


model User {
  id    String     @id  @default(uuid())
  email  String @unique
  password String
  role Role @default(CANDIDATE)
}

enum Role{
  CANDIDATE
  RECRUITER
  ADMIN
}